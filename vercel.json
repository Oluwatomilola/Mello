{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "other",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "regions": ["auto"],
  "env": {
    "NODE_ENV": "production"
  }
}
